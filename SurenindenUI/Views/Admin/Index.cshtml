@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Toplam Kullanıcı</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalUsers">Yükleniyor...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const apiUrl = "https://localhost:7008/api/";

            $.ajax({
                url: apiUrl + "Auth/users",
                type: "GET",
                success: function (data) {
                    $("#totalUsers").text(data.length);
                },
                error: function () {
                    $("#totalUsers").text("Hata!");
                }
            });
        });
    </script>
}