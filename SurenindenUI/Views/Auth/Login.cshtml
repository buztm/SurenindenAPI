@{
    ViewData["Title"] = "Giriş Yap - Sureninden";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/sbadmin/vendor/fontawesome-free/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --brand-yellow: #FFD700;
            --brand-dark: #1A1A1A;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.75)), url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            border: 1px solid rgba(255, 215, 0, 0.2);
            border-radius: 24px;
            background: rgba(26, 26, 26, 0.85);
            backdrop-filter: blur(15px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 420px;
            overflow: hidden;
        }

        .login-header {
            padding: 3rem 2rem 1.5rem;
            text-align: center;
        }

        .brand-icon-box {
            width: 70px;
            height: 70px;
            background: var(--brand-yellow);
            color: var(--brand-dark);
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            transform: rotate(-10deg);
            box-shadow: 0 10px 20px rgba(255, 215, 0, 0.3);
        }

        .brand-title {
            color: white;
            font-weight: 800;
            font-size: 1.8rem;
            letter-spacing: 1px;
            margin-bottom: 0;
            text-transform: uppercase;
        }

        .brand-subtitle {
            color: var(--brand-yellow);
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-top: 5px;
            opacity: 0.9;
        }

        .custom-input {
            border-radius: 12px;
            padding: 0.85rem 1.2rem;
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.05) !important;
            color: white !important;
            font-weight: 400;
            transition: all 0.3s;
        }

            .custom-input::placeholder {
                color: rgba(255,255,255,0.4);
            }

            .custom-input:focus {
                background: rgba(255,255,255,0.1) !important;
                border-color: var(--brand-yellow);
                box-shadow: 0 0 0 0.25rem rgba(255,215,0,0.15);
            }

        .form-label {
            font-weight: 600;
            color: rgba(255,255,255,0.6);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-left: 5px;
        }

        .btn-premium {
            background: var(--brand-yellow);
            color: var(--brand-dark);
            font-weight: 700;
            border: none;
            padding: 1rem;
            border-radius: 14px;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 1rem;
        }

            .btn-premium:hover {
                background-color: #fff;
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(255, 215, 0, 0.4);
            }

        .footer-text {
            color: rgba(255,255,255,0.5);
            font-size: 0.85rem;
        }

        .register-link {
            color: var(--brand-yellow);
            text-decoration: none;
            font-weight: 700;
            transition: 0.3s;
        }

            .register-link:hover {
                color: white;
            }

        .alert {
            background: rgba(220, 53, 69, 0.2);
            border: 1px solid rgba(220, 53, 69, 0.4);
            color: #ff8d97;
            border-radius: 12px;
            font-size: 0.85rem;
        }

        .alert-success {
            background: rgba(25, 135, 84, 0.2);
            border: 1px solid rgba(25, 135, 84, 0.4);
            color: #7ef2bb;
        }
    </style>
</head>

<body>
    <div class="container px-3">
        <div class="row justify-content-center">
            <div class="card login-card">
                <div class="login-header">
                    <div class="brand-icon-box">
                        <i class="fas fa-car fa-2x"></i>
                    </div>
                    <h1 class="brand-title">Sureninden</h1>
                    <div class="brand-subtitle">Exclusive Drive</div>
                </div>

                <div class="card-body p-4 p-md-4">
                    <form id="loginForm">
                        <div class="mb-3">
                            <label class="form-label">Kullanıcı Adı</label>
                            <input type="text" class="form-control custom-input" id="username" placeholder="Kullanıcı adınızı yazın" required autocomplete="off">
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Şifre Bilgisi</label>
                            <input type="password" class="form-control custom-input" id="password" placeholder="••••••••" required autocomplete="off">
                        </div>

                        <div id="loginAlert"></div>

                        <button type="submit" class="btn btn-premium w-100 mb-3" id="loginBtn">
                            Giriş Yap <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <div class="text-center mt-4 mb-2">
                        <p class="footer-text mb-0">Henüz bir hesabınız yok mu?</p>
                        <a href="/auth/register" class="register-link">Ücretsiz Kayıt Ol</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/sbadmin/vendor/jquery/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/api-service.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        $(document).ready(function() {
            $('#loginForm').on('submit', function(e) {
                e.preventDefault();
                login();
                return false;
            });
        });

        function login() {
            const username = $('#username').val();
            const password = $('#password').val();
            const btn = $('#loginBtn');

            if (!username || !password) {
                showLoginAlert('Lütfen tüm alanları doldurun.', 'warning');
                return false;
            }

            btn.prop('disabled', true).html('<i class="fas fa-circle-notch fa-spin"></i>');

            ApiService.auth.login(username, password)
                .then(data => {
                    if (data && data.token) {
                        ApiService.setToken(data.token);
                        localStorage.setItem('authUser', JSON.stringify({
                            id: data.userId || data.id,
                            userName: data.userName || username,
                            email: data.email || '',
                            roles: data.roles || []
                        }));

                        const isAdmin = (data.roles || []).some(r => r.toLowerCase() === 'admin');
                        window.location.href = isAdmin ? '/admin/dashboard' : '/';
                    }
                })
                .catch(error => {
                    const msg = error.responseJSON?.message || 'Giriş başarısız. Bilgilerinizi kontrol edin.';
                    showLoginAlert(msg, 'danger');
                    btn.prop('disabled', false).html('Giriş Yap <i class="fas fa-arrow-right ms-2"></i>');
                });

            return false;
        }

        function showLoginAlert(message, type) {
            const alert = `<div class="alert alert-${type} border-0 shadow-sm mb-4" role="alert">${message}</div>`;
            $('#loginAlert').html(alert);
        }
    </script>
</body>
</html>