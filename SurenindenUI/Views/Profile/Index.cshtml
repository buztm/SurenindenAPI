@{
    Layout = "_Layout";
    ViewData["Title"] = "Profilim";
}

<style>
    :root {
        --brand-yellow: #FFD700;
        --brand-dark: #1A1A1A;
    }

    .profile-hero {
        background: linear-gradient(135deg, var(--brand-dark) 0%, #2c2c2c 100%);
        border-radius: 24px;
        padding: 4rem 3rem;
        color: white;
        margin-bottom: 2.5rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        border: 1px solid rgba(255, 215, 0, 0.1);
    }

        .profile-hero::after {
            content: '\f1b9';
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            position: absolute;
            right: -30px;
            bottom: -50px;
            font-size: 18rem;
            color: rgba(255,215,0,0.03);
            transform: rotate(-10deg);
            pointer-events: none;
        }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 1.8rem;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        height: 100%;
        border: 1px solid rgba(0,0,0,0.02);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

    .stat-icon-box {
        width: 55px;
        height: 55px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin: 0 auto 1.2rem;
        transition: 0.3s;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--brand-dark);
        margin-bottom: 0.2rem;
    }

    .stat-label {
        color: #888;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .premium-card {
        border: none;
        border-radius: 24px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        background: white;
    }

    .card-header-premium {
        background: transparent;
        border-bottom: 1px solid #f1f3f9;
        padding: 1.8rem;
    }

    .custom-input {
        border-radius: 12px;
        padding: 0.85rem 1.2rem;
        border: 2px solid #f1f3f9;
        background-color: #f8f9fa;
        font-weight: 500;
        transition: all 0.3s;
    }

        .custom-input:focus {
            background-color: white;
            border-color: var(--brand-yellow);
            box-shadow: 0 0 0 0.25rem rgba(255,215,0,0.1);
        }

    .btn-update {
        background: var(--brand-yellow);
        color: var(--brand-dark);
        border: none;
        padding: 1rem;
        border-radius: 15px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

        .btn-update:hover {
            background: var(--brand-dark);
            color: var(--brand-yellow);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

    .rental-table thead th {
        background: #f8f9fa;
        border: none;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #aaa;
        padding: 1.2rem;
    }
</style>

<div class="profile-hero">
    <div class="row align-items-center position-relative" style="z-index: 1;">
        <div class="col-md-8">
            <span class="text-warning small fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 3px;">Kullanıcı Paneli</span>
            <h1 class="fw-bold mb-3">Hoş Geldin, <span id="heroUserName" class="text-warning">...</span>!</h1>
            <p class="mb-0 text-white-50 fw-light" style="max-width: 600px;">Kiralama geçmişini takip edebilir, profil detaylarını güncelleyebilir ve sürüş deneyimini kişiselleştirebilirsin.</p>
        </div>
        <div class="col-md-4 text-md-end mt-4 mt-md-0">
            <div id="heroRoleBadge" class="d-inline-block px-4 py-2 bg-white bg-opacity-10 border border-white border-opacity-20 rounded-pill text-warning fw-bold shadow-sm">
                Yükleniyor...
            </div>
        </div>
    </div>
</div>

<div class="row mb-5 g-4">
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon-box bg-dark text-warning"><i class="fas fa-history"></i></div>
            <div class="stat-value" id="totalRentals">0</div>
            <div class="stat-label">Toplam Kayıt</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon-box bg-primary bg-opacity-10 text-primary"><i class="fas fa-play-circle"></i></div>
            <div class="stat-value" id="activeRentals">0</div>
            <div class="stat-label">Aktif Sürüş</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon-box bg-success bg-opacity-10 text-success"><i class="fas fa-check-double"></i></div>
            <div class="stat-value" id="completedRentals">0</div>
            <div class="stat-label">Tamamlanan</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon-box bg-warning bg-opacity-10 text-dark"><i class="fas fa-coins"></i></div>
            <div class="stat-value" id="totalSpent">₺0</div>
            <div class="stat-label">Toplam Ödeme</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-lg-4">
        <div class="card premium-card h-100">
            <div class="card-header-premium">
                <h5 class="fw-bold mb-0 text-dark">Profil Ayarları</h5>
            </div>
            <div class="card-body p-4">
                <form id="profileForm">
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-muted text-uppercase">Görünür Ad</label>
                        <input type="text" id="profileUserName" class="form-control custom-input" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-muted text-uppercase">E-Posta</label>
                        <input type="email" id="profileEmail" class="form-control custom-input" required>
                    </div>

                    <div class="p-3 mb-4 rounded-4" style="background: #f8f9fc; border: 1px dashed #dee2e6;">
                        <h6 class="fw-bold mb-3 small text-dark"><i class="fas fa-shield-alt text-warning me-2"></i>GÜVENLİK</h6>
                        <div class="mb-3">
                            <input type="password" id="profilePassword" class="form-control border-0 shadow-sm" placeholder="Yeni Şifre (İsteğe bağlı)" style="border-radius: 10px;">
                        </div>
                        <div class="mb-0">
                            <input type="password" id="profileConfirmPassword" class="form-control border-0 shadow-sm" placeholder="Şifre Tekrar" style="border-radius: 10px;">
                        </div>
                    </div>

                    <div id="profileAlert"></div>
                    <button type="button" class="btn btn-update w-100 shadow-sm" id="updateProfileBtn" onclick="saveProfile()">Değişiklikleri Kaydet</button>
                    <input type="hidden" id="profileId" />
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card premium-card h-100">
            <div class="card-header-premium d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0 text-dark">Kiralama Geçmişi</h5>
                <button class="btn btn-sm btn-light rounded-pill px-3 fw-bold" onclick="loadProfileData()"><i class="fas fa-sync-alt me-1"></i>Yenile</button>
            </div>
            <div class="card-body p-0">
                <div id="rentalHistory">
                    <div class="text-center py-5">
                        <i class="fas fa-circle-notch fa-spin fa-2x text-warning"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadProfileData();
        });

        function isActuallySuccess(error) {
            if (!error) return false;
            if (error instanceof SyntaxError || (error.message && error.message.toLowerCase().includes('json'))) return true;
            if (error.status && error.status >= 200 && error.status < 300) return true;
            return false;
        }

        function loadProfileData() {
            const stored = localStorage.getItem('authUser');
            const token = ApiService.getToken();

            if (!stored || !token) { window.location.href = '/auth/login'; return; }

            const user = JSON.parse(stored);
            const userId = user.id || user.userId || '';
            $('#profileId').val(userId);

            let rolesDisplay = 'Üye';
            if (user.roles && user.roles.includes('Admin')) {
                rolesDisplay = '<i class="fas fa-crown me-2 text-warning"></i>Sistem Yöneticisi';
            }
            $('#heroRoleBadge').html(rolesDisplay);

            let tokenEmail = '', tokenUsername = '';
            try {
                const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
                tokenEmail = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress'] || payload.email || '';
                tokenUsername = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name'] || payload.unique_name || '';
            } catch (e) { }

            $('#profileUserName').val(tokenUsername || user.userName || '');
            $('#profileEmail').val(tokenEmail || user.email || '');
            $('#heroUserName').text(tokenUsername || user.userName || 'Sürücü');

            if (userId) loadRentals(userId);
        }

        function loadRentals(userId) {
            ApiService.rentals.getMyRentals(userId)
                .then(data => {
                    let total = 0, active = 0, completed = 0, spent = 0;

                    if (!data || data.length === 0) {
                        $('#rentalHistory').html('<div class="text-center py-5"><i class="fas fa-car-slash fa-3x mb-3 opacity-25"></i><p class="text-muted">Henüz kiralama kaydınız bulunmuyor.</p></div>');
                        return;
                    }

                    let html = `<div class="table-responsive"><table class="table rental-table table-hover align-middle mb-0"><thead><tr><th class="ps-4">Araç</th><th>Tarih</th><th>Tutar</th><th class="text-center">Durum</th></tr></thead><tbody>`;

                    data.forEach(r => {
                        total++; spent += (r.totalPrice || 0);
                        const isReturned = r.returnDate && new Date(r.returnDate).getFullYear() > 2000;
                        if (!isReturned) active++; else completed++;

                        const badge = isReturned ?
                            '<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill">Tamamlandı</span>' :
                            '<span class="badge bg-warning bg-opacity-10 text-dark border border-warning border-opacity-25 px-3 py-2 rounded-pill">Müşteride</span>';

                        html += `<tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">Araç #${r.carId}</div>
                                <small class="text-muted">İşlem: ${r.id}</small>
                            </td>
                            <td class="small">
                                <div><b>B:</b> ${new Date(r.rentDate).toLocaleDateString('tr-TR')}</div>
                                <div><b>İ:</b> ${isReturned ? new Date(r.returnDate).toLocaleDateString('tr-TR') : '--'}</div>
                            </td>
                            <td class="fw-bold text-dark">₺${(r.totalPrice || 0).toLocaleString('tr-TR')}</td>
                            <td class="text-center">${badge}</td>
                        </tr>`;
                    });

                    $('#rentalHistory').html(html + '</tbody></table></div>');
                    $('#totalRentals').text(total);
                    $('#activeRentals').text(active);
                    $('#completedRentals').text(completed);
                    $('#totalSpent').text('₺' + spent.toLocaleString('tr-TR'));
                });
        }

        function saveProfile() {
            const id = $('#profileId').val(), user = $('#profileUserName').val(), email = $('#profileEmail').val(), pass = $('#profilePassword').val(), conf = $('#profileConfirmPassword').val();
            const btn = $('#updateProfileBtn');

            if (pass && pass !== conf) { showProfileAlert('Şifreler eşleşmiyor!', 'warning'); return; }

            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

            ApiService.auth.updateUser(id, user, email, pass)
                .then(() => handleUpdate())
                .catch(err => { if (isActuallySuccess(err)) handleUpdate(); else { showProfileAlert('Hata oluştu!', 'danger'); btn.prop('disabled', false).text('Değişiklikleri Kaydet'); } });
        }

        function handleUpdate() {
            showProfileAlert('Profil güncellendi! Yeniden giriş yapılıyor...', 'success');
            setTimeout(() => { ApiService.removeToken(); localStorage.removeItem('authUser'); window.location.href = '/auth/login'; }, 2000);
        }

        function showProfileAlert(msg, type) {
            const alert = `<div class="alert alert-${type} border-0 shadow-sm mt-3" style="border-radius:12px;">${msg}</div>`;
            $('#profileAlert').html(alert);
        }
    </script>
}